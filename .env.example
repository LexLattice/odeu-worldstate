# Server-only OpenAI credential. Leave blank while using fixture/replay modes.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# fixture | live
ODEU_MANAGER_MODE=fixture

# replay | live
ODEU_CODEX_MODE=replay

# Required for browser-triggered live authority, private status, validation,
# and promotion routes. The origin must exactly match the public app origin and
# use HTTPS, except for an exact localhost/127.0.0.1/[::1] development origin.
ODEU_OPERATOR_ALLOWED_ORIGIN=http://localhost:3000
# At least 32 bytes. Supply to the browser only as a transient in-memory
# operator credential; never place it in storage, a request body, or a query.
ODEU_OPERATOR_BEARER_SECRET=

# Required only for a live Codex worker.
# Optional when OPENAI_API_KEY is already configured.
CODEX_API_KEY=
ODEU_CODEX_WORKSPACE=
ODEU_CODEX_MODEL=
ODEU_CODEX_HOME=
# Validated exported ledger in a private, server-writable directory disjoint from
# both workspace and Codex home. Neither the file nor any parent may be a symlink.
# The host stores per-run guard and claim markers beside it.
ODEU_CODEX_LEDGER_FILE=
ODEU_CODEX_AUTH_SECRET=

# Required for sealing every returned live workspace as a signed,
# non-authoritative Git candidate before the execution lease is released.
ODEU_CODEX_REPOSITORY_ID=
ODEU_CODEX_PROMOTION_TARGET_REF=refs/heads/main
ODEU_CODEX_CANDIDATE_STORE=
ODEU_CODEX_ARTIFACT_SIGNING_KEY_ID=
# At least 32 bytes. Keep server-only and distinct from run authorization.
ODEU_CODEX_ARTIFACT_SIGNING_SECRET=

# Independent live-candidate verifier registries. JSON maps are resolved only
# on the server; neither repository nor toolchain paths come from the browser.
# Shape: {"<key-id>":"<same artifact signing secret>"}.
ODEU_LIVE_EVIDENCE_SIGNING_SECRETS={}
# {"<repository-id>":{"repositoryPath":"/absolute/repository","toolchainPath":"/optional/read-only/toolchain"}}
ODEU_LIVE_EVIDENCE_REPOSITORIES={}

# Dedicated bare authoritative promotion repository and durable status
# directory. The status store must be on a native private POSIX filesystem;
# descriptor-anchored no-follow access currently assumes Linux /proc. The
# configured repository path must be the exact bare-repository root; its
# target branch must not be checked out in any linked worktree when the human
# CAS is performed. Promotion never rebases, cherry-picks, or updates a worktree.
ODEU_CODEX_PROMOTION_REPOSITORY=
ODEU_CODEX_PROMOTION_STATUS_STORE=

# Set only when a disposable standalone clone is used instead of a linked worktree.
ODEU_CODEX_ALLOW_PRIMARY_WORKTREE=false
